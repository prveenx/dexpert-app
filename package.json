{
  "name": "dexpert",
  "version": "0.1.0",
  "private": true,
  "description": "Dexpert — AI multi-agent desktop platform",
  "author": "Dexpert Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*",
    "engine"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --ui=tui",
    "dev:tui": ".\\engine\\.venv\\Scripts\\python.exe scripts/tui_dev.py",
    "dev:desktop": "turbo run dev --filter=@dexpert/desktop",
    "dev:web": "turbo run dev --filter=@dexpert/web",
    "dev:engine": "cd engine && .\\.venv\\Scripts\\python.exe main.py",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:push": "pnpm --filter @dexpert/db db:push",
    "db:seed": "pnpm --filter @dexpert/db db:seed"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^0.577.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  }
}
